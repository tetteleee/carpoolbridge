rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 認証済み(匿名含む)かつ staffUsers に自分のUIDが登録されている人だけ
    // 読み書きを許可する。
    //
    // MVP運用:
    //   1. 利用者が初回アクセスすると匿名認証でUIDが発行される
    //   2. 発行されたUIDを画面に表示し、管理者へ「利用申請」する
    //      （初期段階ではLINE等で口頭連絡→管理者がFirebase Consoleで
    //        staffUsers/{uid} ドキュメントを手動作成でよい）
    //   3. pendingUsers → staffUsers への承認UIは後続フェーズで実装する
    //
    // 保護者向け機能(Phase2)を追加する際は、families コレクションの
    // 存在チェックに拡張した isFamily() のような関数を追加する想定。
    function isStaff() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/staffUsers/$(request.auth.uid));
    }

    match /staffUsers/{uid} {
      // 自分自身のstaffUsersドキュメントの有無だけは確認できるようにする
      // (アプリ側で「承認待ちです」の表示分岐に使うため)。
      // 書き込みは一切許可しない(Firebase Consoleまたは今後の管理画面/
      // Cloud Functions経由でのみ作成する)。
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list, write: if false;
    }

    match /pendingUsers/{uid} {
      // 利用申請は本人のみ作成可能。承認(削除)は管理側の作業とする。
      allow create: if request.auth != null && request.auth.uid == uid;
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list, update, delete: if false;
    }

    match /families/{familyId} {
      allow read, write: if isStaff();
    }

    match /children/{childId} {
      allow read, write: if isStaff();
    }

    match /coaches/{coachId} {
      allow read, write: if isStaff();
    }

    match /pickupLocations/{locationId} {
      allow read, write: if isStaff();
    }

    match /destinations/{destinationId} {
      allow read, write: if isStaff();
    }

    match /events/{eventId} {
      allow read, write: if isStaff();

      match /responses/{familyId} {
        allow read, write: if isStaff();
      }

      match /carpools/{carpoolId} {
        allow read, write: if isStaff();
      }
    }

    // 上記いずれにも該当しないパスはデフォルトで拒否する
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
