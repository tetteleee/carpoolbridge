# E2Eテスト（Playwright + Firebase Emulator Suite）専用の設定。
# 実際のFirebaseプロジェクトには接続しないため、ダミー値で問題ない。
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-carpoolbridge-e2e.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-carpoolbridge-e2e
VITE_FIREBASE_STORAGE_BUCKET=demo-carpoolbridge-e2e.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_USE_FIREBASE_EMULATOR=true
